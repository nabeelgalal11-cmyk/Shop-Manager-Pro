// Used car inventory & sales summary
router.get("/used-cars", async (_req, res) => {
  const byStatus = await q(sql`
    SELECT
      status,
      COUNT(*)::int                                             AS count,
      COALESCE(SUM(selling_price), 0)::numeric                 AS total_selling,
      COALESCE(SUM(purchase_price), 0)::numeric                AS total_cost,
