    totalRevenue?: number;
    totalExpenses?: number;
    usedCarProfit?: number;
    cogs?: number;
    totalProfit?: number;
    servicePaid?: number;
    onlinePayments?: number;
    usedCarSoldRevenue?: number;
    usedCarSoldCount?: number;
    usedCarAvailableCount?: number;
  }
