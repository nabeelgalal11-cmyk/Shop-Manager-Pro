          <div><span>Tax ({estimate.taxRate}%)</span><span>{formatCurrency(Number(estimate.taxAmount))}</span></div>
          <div className="grand"><span>Total</span><span>{formatCurrency(Number(estimate.total))}</span></div>
        </div>
      </div>
    </div>
