                  </Badge>
                  {decisionBadge(it.customerDecision)}
                </div>
              </div>
              {Array.isArray(it.photos) && it.photos.length > 0 && (
                <div className="flex flex-wrap gap-2 mt-2">
                  {it.photos.map((p: string, j: number) => (
