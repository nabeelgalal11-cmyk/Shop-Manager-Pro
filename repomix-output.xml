components:
  schemas:
    HealthStatus:
      type: object
      properties:
        status:
          type: string
      required:
        - status

    Customer:
      type: object
      properties:
        id:
          type: integer
        firstName:
          type: string
        lastName:
          type: string
        email:
          type: string
        phone:
          type: string
        address:
          type: string
        city:
          type: string
        state:
          type: string
        zip:
          type: string
        notes:
          type: string
        categoryId:
          type: integer
          nullable: true
        preferredChannel:
          type: string
          enum: [email, sms, both]
        smsOptOut:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        vehicleCount:
          type: integer
        totalBilled:
          type: number
        totalPaid:
          type: number
      required:
        - id
        - firstName
        - lastName
        - createdAt
        - updatedAt

    CreateCustomerInput:
      type: object
      properties:
        firstName:
          type: string
        lastName:
          type: string
        email:
          type: string
        phone:
          type: string
        address:
          type: string
        city:
          type: string
        state:
          type: string
        zip:
          type: string
        notes:
          type: string
        categoryId:
          type: integer
          nullable: true
        preferredChannel:
          type: string
          enum: [email, sms, both]
        smsOptOut:
          type: string
      required:
        - firstName
        - lastName

    UpdateCustomerInput:
      type: object
      properties:
        firstName:
          type: string
        lastName:
          type: string
        email:
          type: string
        phone:
          type: string
        address:
          type: string
        city:
          type: string
        state:
          type: string
