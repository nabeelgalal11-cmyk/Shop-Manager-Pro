                                  : "bg-background text-muted-foreground hover:bg-muted"
                              }`}
                              onClick={() => !part.useUsed && togglePart(i, "useUsed")}
                            >
                              Used
                            </button>
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Fluids */}
            {result.fluids.length > 0 && (
              <div>
                <div className="flex items-center gap-2 mb-2">
