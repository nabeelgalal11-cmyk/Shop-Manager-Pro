                <div className="rounded-md border p-3">
                  <div className="text-xs text-muted-foreground">Asking / Sold</div>
                  <div className="font-semibold">{fmt(Number(form.sellingPrice || 0))}</div>
                </div>
                <div className="rounded-md border p-3">
