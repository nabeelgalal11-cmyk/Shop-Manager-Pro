                  <TableCell className="text-right">{entry.cost ? formatCurrency(entry.cost) : "—"}</TableCell>
                </TableRow>
              )) : (
                <TableRow>
                  <TableCell colSpan={4} className="text-center py-8 text-muted-foreground">No service history.</TableCell>
