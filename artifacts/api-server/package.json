    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "0.45.2",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "memorystore": "^1.6.8",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.77.0",
    "pino": "^10.3.0",
    "pino-http": "^10.5.0",
