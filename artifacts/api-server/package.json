{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && node build.mjs",
    "build:tsc": "tsc -b",
    "start": "node --enable-source-maps dist/index.mjs",
    "dev": "NODE_ENV=development pnpm run build:tsc && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "0.45.2",
    "express": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "openai": "^4.77.0",
    "pino": "^10.3.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.5.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}