{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "start": "tsx index.ts",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "^3.12.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2"
    }
  }
}